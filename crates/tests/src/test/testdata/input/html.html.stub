<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Page Title Here</title>
    <!-- this comment's
        indentation should
        be unchanged
    -->
</head>
<body>
    <div>The script should not be highlighted! An a as well!</div>
    <div class="main">
        <span class="something">Blah</span>
        <span class="something">
            Foobar
        </span>
    </div>

    <script type="text/javascript" src="/some_script.js"></script>

    <main id="content" data-role="page">
        <picture>
            <source srcset="img.webp" type="image/webp" />
            <img src="img.png" alt="Example" />
        </picture>
        <svg width="10" height="10"><path d="M0 0" /></svg>
    </main>

    <noscript>Enable JavaScript</noscript>
    <template id="tpl"><p>Template</p></template>

    <!-- Curly braces -->
    foo {
        bar { <!-- comment -->
            baz
        }
    }
    text
    { <p></p> }
    text
    {{template}}
    text

    <script>
    function test() {
        return 1;
    }

    document.addEventListener('click', function() {
        test();
    });
    </script>
</body>
</html>
