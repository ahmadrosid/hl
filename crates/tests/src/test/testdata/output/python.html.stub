<tr><td class="hl-num" data-line="109"></td><td>    <span class="hl-k">match</span> value:</td></tr>
<tr><td class="hl-num" data-line="110"></td><td>        <span class="hl-k">case</span> <span class="hl-c">1</span>:</td></tr>
<tr><td class="hl-num" data-line="111"></td><td>            score <span class="hl-k">+=</span> <span class="hl-c">1</span></td></tr>
<tr><td class="hl-num" data-line="112"></td><td>        <span class="hl-k">case</span> _:</td></tr>
<tr><td class="hl-num" data-line="113"></td><td>            score <span class="hl-k">-=</span> <span class="hl-c">1</span></td></tr>
<tr><td class="hl-num" data-line="114"></td><td>            flags <span class="hl-k">=</span> <span class="hl-c">0</span></td></tr>
<tr><td class="hl-num" data-line="115"></td><td>            flags <span class="hl-k">|=</span> <span class="hl-c">1</span></td></tr>
<tr><td class="hl-num" data-line="116"></td><td>            flags <span class="hl-k"><<=</span> <span class="hl-c">2</span></td></tr>
<tr><td class="hl-num" data-line="117"></td><td>            score <span class="hl-k">//=</span> <span class="hl-c">2</span></td></tr>
